# =============================================================================
# Authelia Railway Template — Environment Variables
# =============================================================================
# Copy this file to .env for local testing.
# On Railway, set these in the service's Variables tab.
# Variables marked [REQUIRED] must be set. Others have defaults.
# =============================================================================

# -----------------------------------------------------------------------------
# DOMAIN & URLs [REQUIRED]
# -----------------------------------------------------------------------------

# Your root domain (e.g. example.com). Authelia will protect *.AUTHELIA_DOMAIN
AUTHELIA_DOMAIN="example.com"

# Full public URL of this Authelia instance (must be HTTPS)
AUTHELIA_AUTH_URL="https://auth.example.com"

# -----------------------------------------------------------------------------
# SECRETS [REQUIRED] — use Railway's ${{secret(32)}} for all of these
# -----------------------------------------------------------------------------

# Session signing secret (min 64 chars recommended)
AUTHELIA_SESSION_SECRET="changeme-use-railway-secret-generator"

# Storage encryption key (min 20 chars)
AUTHELIA_STORAGE_ENCRYPTION_KEY="changeme-use-railway-secret-generator"

# JWT secret for password reset emails
# Note: named AUTH_JWT_SECRET (not AUTHELIA_JWT_SECRET) to avoid conflicting with
# Authelia's deprecated jwt_secret env var mapping
AUTH_JWT_SECRET="changeme-use-railway-secret-generator"

# -----------------------------------------------------------------------------
# POSTGRESQL [REQUIRED] — reference from Railway Postgres service
# -----------------------------------------------------------------------------
# Note: named PG_* (not AUTHELIA_STORAGE_POSTGRES_*) to avoid conflicting with
# Authelia's deprecated storage.postgres.host/port env var mapping

PG_HOST="${{Postgres.PGHOST}}"
PG_PORT="${{Postgres.PGPORT}}"
PG_DATABASE="${{Postgres.PGDATABASE}}"
PG_USERNAME="${{Postgres.PGUSER}}"
PG_PASSWORD="${{Postgres.PGPASSWORD}}"

# -----------------------------------------------------------------------------
# REDIS [REQUIRED] — reference from Railway Redis service
# -----------------------------------------------------------------------------

AUTHELIA_SESSION_REDIS_HOST="${{Redis.REDISHOST}}"
AUTHELIA_SESSION_REDIS_PORT="${{Redis.REDISPORT}}"
AUTHELIA_SESSION_REDIS_PASSWORD="${{Redis.REDIS_PASSWORD}}"

# -----------------------------------------------------------------------------
# USERS [REQUIRED on first boot only]
# Two modes — pick one:
#
# Multi-user (recommended): AUTH_USERS="user|pass|email|display|groups;user2|..."
#   Fields after password are optional. Groups comma-separated.
#   Example: "alice|pass1|alice@example.com|Alice|admins,users;bob|pass2"
#
# Single-user (legacy): set AUTHELIA_INIT_* vars below instead.
#   Only used if AUTH_USERS is not set.
# -----------------------------------------------------------------------------

# Option A — multi-user (recommended)
# AUTH_USERS="admin|changeme|admin@example.com|Administrator|admins,users"

# Option B — single-user (legacy)
AUTHELIA_INIT_USERNAME="admin"
AUTHELIA_INIT_PASSWORD="changeme-set-a-strong-password"
AUTHELIA_INIT_EMAIL="admin@example.com"
AUTHELIA_INIT_DISPLAY_NAME="Administrator"

# -----------------------------------------------------------------------------
# SESSION [OPTIONAL — defaults shown]
# -----------------------------------------------------------------------------

SESSION_NAME="authelia_session"
SESSION_EXPIRATION="1h"
SESSION_INACTIVITY="5m"
SESSION_REMEMBER_ME="1M"

# -----------------------------------------------------------------------------
# ACCESS CONTROL [OPTIONAL — defaults shown]
# default_policy applies to any domain not matched by a specific rule.
# Options: bypass | one_factor | two_factor | deny
# -----------------------------------------------------------------------------

ACCESS_CONTROL_DEFAULT_POLICY="two_factor"

# Add extra YAML rules here (advanced). Must be valid YAML list items.
# Example: "- domain: public.example.com\n  policy: bypass"
# ACCESS_CONTROL_RULES_EXTRA=""

# -----------------------------------------------------------------------------
# REGULATION [OPTIONAL — defaults shown]
# How Authelia handles brute-force login attempts
# -----------------------------------------------------------------------------

REGULATION_MAX_RETRIES="3"
REGULATION_FIND_TIME="2m"
REGULATION_BAN_TIME="5m"

# -----------------------------------------------------------------------------
# LOGGING [OPTIONAL]
# Options: trace | debug | info | warn | error
# -----------------------------------------------------------------------------

AUTHELIA_LOG_LEVEL="info"

# -----------------------------------------------------------------------------
# 2FA METHOD [OPTIONAL]
# Options: totp | webauthn | mobile_push
# -----------------------------------------------------------------------------

AUTHELIA_DEFAULT_2FA_METHOD="totp"

# -----------------------------------------------------------------------------
# SMTP NOTIFIER [OPTIONAL]
# If SMTP_HOST is set, Authelia uses SMTP for 2FA and reset emails.
# If not set, emails are written to /config/notifications.txt (testing only).
# -----------------------------------------------------------------------------

# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USERNAME="you@gmail.com"
# SMTP_PASSWORD="your-app-password"
# SMTP_SENDER="Authelia <authelia@example.com>"

# -----------------------------------------------------------------------------
# OIDC PROVIDER [OPTIONAL]
# Enables Authelia as an OpenID Connect provider for other apps
# (e.g. Gitea, Grafana, Portainer, Nextcloud, etc.)
# All three vars below must be set together to enable OIDC.
# -----------------------------------------------------------------------------

# OIDC_CLIENT_ID="my-app"
# OIDC_CLIENT_NAME="My App"
# OIDC_CLIENT_SECRET="changeme-strong-secret"
# OIDC_REDIRECT_URI="https://my-app.example.com/oauth/callback"
# AUTHELIA_OIDC_HMAC_SECRET="changeme-use-railway-secret-generator"

# -----------------------------------------------------------------------------
# RAILWAY INTERNAL
# -----------------------------------------------------------------------------

# Run as root so Authelia can write to the Railway volume
RAILWAY_RUN_UID="0"
